# AWS credentials (fill with your AWS access keys and regions)
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGIONS=us-east-1,us-west-2,eu-west-1  # Comma-separated list of regions to monitor

# Detection configuration
MAX_EVENTS=50  # Maximum number of events to fetch per region
LOOKBACK_HOURS=24  # How many hours back to look for events

# Email credentials for sending alerts (fill with your email credentials)
SENDER_EMAIL=your_sender_email_here
EMAIL_PASSWORD=your_email_password_here  # If using Gmail, generate an App Password for this
RECEIVER_EMAIL=your_receiver_email_here

# Slack webhook (optional - leave empty if not using Slack)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
